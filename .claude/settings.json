{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/next_runs.py || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/validate_board.py || true"
          },
          {
            "type": "command",
            "command": "python .claude/scripts/validate_prompts.py || true"
          }
        ]
      }
    ]
  }
}
