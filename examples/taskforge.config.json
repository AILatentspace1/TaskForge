{
  "version": 1,
  "project_name": "example-project",
  "target_repo": "/path/to/example-project",
  "runtime_dir": ".team",
  "remote": "origin",
  "base_branch": "main",
  "github_repo": "owner/example-project",
  "north_star": "Describe the durable project mission that automation must stay inside.",
  "allowed_paths": [
    "src/**",
    "docs/**",
    "tests/**"
  ],
  "prompt_source": "/path/to/TaskForge/prompts",
  "platforms": ["codex", "claude"],
  "default_platform": "claude",
  "automations": {
    "codex": {
      "planner": "team-planner.codex.md",
      "heartbeat": "team-heartbeat.codex.md",
      "retro": "team-retro.codex.md"
    },
    "claude": {
      "planner": "team-planner.claude.md",
      "heartbeat": "team-heartbeat.claude.md",
      "retro": "team-retro.claude.md"
    }
  }
}
