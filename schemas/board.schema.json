{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taskforge.local/schemas/board.schema.json",
  "title": "TaskForge Board",
  "type": "object",
  "required": ["version", "updated_at", "goals", "tasks", "stats"],
  "properties": {
    "version": { "type": "integer", "minimum": 1, "description": "Board schema version. v3 adds platform fields (created_by_platform, last_platform) and enhanced lock format." },
    "updated_at": { "type": "string" },
    "goals": { "type": "array", "items": { "type": "object" } },
    "initiatives": {
      "type": "array",
      "description": "Goal 和 Task 之间的组织层，将相关任务分组为可追踪的工作流",
      "items": { "$ref": "./initiative.schema.json" }
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "./task.schema.json" }
    },
    "branch_metadata_schema": {
      "type": "object",
      "properties": {
        "base_remote": { "type": "string" },
        "base_branch": { "type": "string" },
        "branch": { "type": ["string", "null"] },
        "merge_base": { "type": ["string", "null"] },
        "base_sha": { "type": ["string", "null"] },
        "head_sha": { "type": ["string", "null"] },
        "last_commit_sha": { "type": ["string", "null"] },
        "last_pushed_sha": { "type": ["string", "null"] },
        "pr_head_sha": { "type": ["string", "null"] },
        "updated_at": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "locks": {
      "type": "object",
      "properties": {
        "pid": { "type": "integer" },
        "started_at": { "type": "string" },
        "automation": { "type": "string" },
        "platform": { "type": "string", "enum": ["codex", "claude"] },
        "hostname": { "type": "string" }
      }
    },
    "dependencies": {
      "type": "array",
      "description": "任务间依赖关系图",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "properties": {
          "from": { "type": "string", "description": "源任务 ID" },
          "to": { "type": "string", "description": "目标任务 ID" },
          "type": { "type": "string", "enum": ["blocking", "optional"], "description": "依赖类型：blocking 表示硬阻塞，optional 表示软依赖" }
        },
        "additionalProperties": false
      }
    },
    "handoffs": {
      "type": "array",
      "description": "跨任务交接事件记录",
      "items": {
        "type": "object",
        "required": ["from_task", "to_task", "artifact", "status", "at"],
        "properties": {
          "from_task": { "type": "string", "description": "交接源任务 ID" },
          "to_task": { "type": "string", "description": "交接目标任务 ID" },
          "artifact": { "type": "string", "description": "交接产物路径" },
          "status": { "type": "string", "enum": ["pending", "in_progress", "accepted", "rejected"], "description": "交接状态" },
          "at": { "type": "string", "description": "交接时间 ISO 8601" },
          "note": { "type": "string", "description": "交接备注" }
        },
        "additionalProperties": false
      }
    },
    "stats": { "type": "object" }
  },
  "additionalProperties": true
}
