{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taskforge.local/schemas/automations.schema.json",
  "title": "TaskForge Automations",
  "description": "Declarative automation rules for TaskForge scheduler. Each rule defines when and how an automation should run.",
  "type": "object",
  "required": ["version", "automations"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version"
    },
    "automations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "schedule", "platform", "prompt_ref"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Unique automation identifier"
          },
          "name": {
            "type": "string",
            "description": "Human-readable name"
          },
          "schedule": {
            "type": "string",
            "description": "Cron expression (5-field). Examples: '5 */6 * * *' (every 6h), '15 */2 * * *' (every 2h), '0 22 * * *' (daily 22:00)"
          },
          "platform": {
            "type": "string",
            "enum": ["claude", "codex"],
            "description": "Target execution platform"
          },
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Whether this automation is active"
          },
          "prompt_ref": {
            "type": "string",
            "description": "Path to the prompt file relative to runtime_dir, e.g. prompts/team-planner.claude.md"
          },
          "timeout_minutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60,
            "default": 25,
            "description": "Maximum execution time in minutes"
          },
          "max_files_modified": {
            "type": "integer",
            "minimum": 1,
            "default": 20,
            "description": "Maximum files the automation may modify per run"
          },
          "max_commits": {
            "type": "integer",
            "minimum": 1,
            "default": 5,
            "description": "Maximum commits per run"
          },
          "max_draft_prs": {
            "type": "integer",
            "minimum": 0,
            "default": 1,
            "description": "Maximum draft PRs the automation may open per run"
          },
          "conditions": {
            "type": "object",
            "description": "Optional preconditions that must be met before execution",
            "properties": {
              "min_active_tasks": {
                "type": "integer",
                "description": "Minimum active tasks required to run"
              },
              "max_active_tasks": {
                "type": "integer",
                "description": "Skip if active tasks exceed this count"
              },
              "require_clean_working_tree": {
                "type": "boolean",
                "default": false,
                "description": "Skip if working tree has uncommitted changes"
              },
              "require_on_base_branch": {
                "type": "boolean",
                "default": true,
                "description": "Only run when on the configured base branch"
              }
            },
            "additionalProperties": false
          },
          "retry": {
            "type": "object",
            "description": "Retry configuration for failed runs",
            "properties": {
              "max_attempts": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5,
                "default": 3
              },
              "backoff_minutes": {
                "type": "integer",
                "minimum": 1,
                "default": 30
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
