{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taskforge.dev/schemas/ai-blocks.schema.json",
  "title": "AIBlock",
  "description": "TaskForge 标准化 AI 操作接口，借鉴 Monday AI 的原子化 AI Block 模式。每个 Block 定义一个可组合的 AI 能力单元。",
  "type": "object",
  "required": ["id", "type", "name", "input", "output"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Block 唯一标识符",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "type": {
      "type": "string",
      "description": "Block 操作类型",
      "enum": ["categorize", "extract", "summarize", "transform", "validate", "custom"]
    },
    "name": {
      "type": "string",
      "description": "Block 显示名称",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "description": "Block 功能描述"
    },
    "input": {
      "type": "object",
      "description": "输入 schema",
      "required": ["schema"],
      "properties": {
        "schema": {
          "type": "object",
          "description": "JSON Schema 定义输入数据结构"
        },
        "examples": {
          "type": "array",
          "description": "输入示例",
          "items": {}
        }
      }
    },
    "output": {
      "type": "object",
      "description": "输出 schema",
      "required": ["schema"],
      "properties": {
        "schema": {
          "type": "object",
          "description": "JSON Schema 定义输出数据结构"
        },
        "examples": {
          "type": "array",
          "description": "输出示例",
          "items": {}
        }
      }
    },
    "trigger": {
      "type": "object",
      "description": "触发条件",
      "properties": {
        "event": {
          "type": "string",
          "description": "触发事件类型",
          "enum": ["on_task_created", "on_state_change", "on_dod_fail", "on_risk_detected", "on_schedule", "manual"]
        },
        "condition": {
          "type": "string",
          "description": "触发条件表达式（可选）"
        },
        "schedule": {
          "type": "string",
          "description": "Cron 表达式（仅 on_schedule 类型）"
        }
      }
    },
    "error_handling": {
      "type": "object",
      "description": "错误处理策略",
      "properties": {
        "max_retries": {
          "type": "integer",
          "description": "最大重试次数",
          "minimum": 0,
          "maximum": 5,
          "default": 1
        },
        "on_failure": {
          "type": "string",
          "description": "失败后的动作",
          "enum": ["skip", "block_task", "notify", "fallback"],
          "default": "notify"
        },
        "fallback_output": {
          "description": "失败时的回退输出"
        }
      }
    },
    "config": {
      "type": "object",
      "description": "Block 运行时配置",
      "properties": {
        "model": {
          "type": "string",
          "description": "推荐的 AI 模型"
        },
        "temperature": {
          "type": "number",
          "description": "模型温度",
          "minimum": 0,
          "maximum": 2
        },
        "timeout_seconds": {
          "type": "integer",
          "description": "超时时间（秒）",
          "minimum": 1,
          "maximum": 600,
          "default": 60
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Block 元数据",
      "properties": {
        "version": {
          "type": "string",
          "description": "Block 版本",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "author": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_research": {
          "type": "string",
          "description": "灵感来源调研文档"
        }
      }
    }
  },
  "additionalProperties": false
}
